FROM credit_quotient-base

COPY prisma /app/prisma
RUN prisma generate --schema=prisma/schema.prisma
COPY worker /app/worker

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 PYTHONPATH=/app
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl libatomic1 tesseract-ocr poppler-utils \
 && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y nodejs \
 && rm -rf /var/lib/apt/lists/*

# Install torch with ROCm support for AMD GPU (adjust index URL to your ROCm version)
# Check ROCm version on host: rocm-smi --version
# For ROCm 6.1 use: --index-url https://download.pytorch.org/whl/rocm6.1
RUN pip install torch==2.5.1 --index-url https://download.pytorch.org/whl/rocm6.1 --no-cache-dir --disable-pip-version-check

COPY shared /app/shared
COPY requirements.txt /app/requirements.txt
RUN pip install --timeout=600 --retries=5 -e /app/shared -r /app/requirements.txt httpx

# Ensure vLLM and transformers are installed (vLLM requires torch already)
RUN pip install vllm==0.6.3.post1 transformers accelerate

CMD ["celery", "-A", "worker.queue.celery_app.celery_app", "worker", "--loglevel=INFO", "--concurrency=1"]