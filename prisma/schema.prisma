datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = -1
  enable_experimental_decimal = true
}

model User {
  id                    String          @id @default(uuid())
  phoneNumber           String          @unique @map("phone_number")
  passwordHash          String?         @map("password_hash")
  pinHash               String?         @map("pin_hash")
  fullName              String?         @map("full_name")
  countryCode           String?         @map("country_code")
  primaryWorkType       String?         @map("primary_work_type")
  onboardingCompletedAt DateTime?       @map("onboarding_completed_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  sessions              DeviceSession[]
  otpChallenges         OtpChallenge[]
  evidence              EvidenceRecord[]
  extractedEvents       ExtractedEvent[]
  scoreSnapshots        ScoreSnapshot[]
  jobs                  JobStatus[]
  cases                 InvestigationCase[]
  notifications         Notification[]

  @@map("users")
}

model InvestigationCase {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  caseNumber  String   @unique @map("case_number")
  title       String
  category    String
  status      String
  priority    String
  riskScore   Int      @map("risk_score")
  amount      Decimal? @db.Decimal(18, 2)
  currency    String   @default("NGN")
  summary     String
  flags       Json     @default("[]")
  timeline    Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("investigation_cases")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String
  tone      String   @default("info")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model DeviceSession {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @unique @map("refresh_token_hash")
  deviceIdHash     String?   @map("device_id_hash")
  deviceName       String?   @map("device_name")
  trusted          Boolean   @default(false)
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("device_sessions")
}

model OtpChallenge {
  id                String    @id @default(uuid())
  userId            String?   @map("user_id")
  phoneNumber       String    @map("phone_number")
  otpHash           String    @map("otp_hash")
  purpose           String
  attempts          Int       @default(0)
  maxAttempts       Int       @default(5) @map("max_attempts")
  resendAvailableAt DateTime  @map("resend_available_at")
  expiresAt         DateTime  @map("expires_at")
  consumedAt        DateTime? @map("consumed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber, purpose])
  @@index([expiresAt])
  @@map("otp_challenges")
}

model EvidenceRecord {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  status           String           @default("PENDING")
  originalFilename String?          @map("original_filename")
  mimeType         String?          @map("mime_type")
  fileSizeBytes    Int?             @map("file_size_bytes")
  storageKey       String?          @map("storage_key")
  fileSha256       String?          @map("file_sha256")
  perceptualHash   String?          @map("perceptual_hash")
  rawText          String?          @map("raw_text")
  note             String?
  detectedSource   String?          @map("detected_source")
  validationFlags  Json             @default("[]") @map("validation_flags")
  fraudFlags       Json             @default("[]") @map("fraud_flags")
  confidence       Float            @default(0)
  errorCode        String?          @map("error_code")
  createdAt        DateTime         @default(now()) @map("created_at")
  processedAt      DateTime?        @map("processed_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  events           ExtractedEvent[]
  jobs             JobStatus[]

  @@index([userId, createdAt])
  @@index([userId, fileSha256])
  @@map("evidence_records")
}

model ExtractedEvent {
  id               String         @id @default(uuid())
  userId           String         @map("user_id")
  evidenceId       String         @map("evidence_id")
  eventType        String         @map("event_type")
  occurredAt       DateTime?      @map("occurred_at")
  amount           Decimal?       @db.Decimal(18, 2)
  currency         String         @default("NGN")
  counterparty     String?
  channel          String?
  description      String?
  sourceConfidence Float          @default(0) @map("source_confidence")
  normalizedData   Json           @map("normalized_data")
  createdAt        DateTime       @default(now()) @map("created_at")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidence         EvidenceRecord @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([evidenceId])
  @@map("extracted_events")
}

model ScoreSnapshot {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  incomeStability      Float    @map("income_stability")
  spendingDiscipline   Float    @map("spending_discipline")
  repaymentReliability Float    @map("repayment_reliability")
  dataConfidence       Float    @map("data_confidence")
  fraudRisk            Float    @map("fraud_risk")
  overallScore         Int      @map("overall_score")
  grade                String
  lenderReadiness      String   @map("lender_readiness")
  recommendedAmount    Decimal? @db.Decimal(18, 2) @map("recommended_amount")
  recommendedTermDays  Int?     @map("recommended_term_days")
  reasoning            Json
  metrics              Json
  createdAt            DateTime @default(now()) @map("created_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("score_snapshots")
}

model JobStatus {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  evidenceId   String?         @map("evidence_id")
  type         String
  status       String          @default("PENDING")
  progress     Int             @default(0)
  errorCode    String?         @map("error_code")
  errorMessage String?         @map("error_message")
  attempts     Int             @default(0)
  startedAt    DateTime?       @map("started_at")
  completedAt  DateTime?       @map("completed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidence     EvidenceRecord? @relation(fields: [evidenceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([evidenceId])
  @@map("job_statuses")
}
